{
  "name": "orion-desktop",
  "version": "1.0.7",
  "description": "Orion — AgentOps floating AI assistant",
  "main": "dist/main.js",
  "scripts": {
    "dev": "tsc && node -e \"require('fs').copyFileSync('src/overlay.html','dist/overlay.html')\" && electron dist/main.js",
    "build": "tsc && node -e \"require('fs').copyFileSync('src/overlay.html','dist/overlay.html')\"",
    "start": "electron dist/main.js",
    "dist": "npm run build && electron-builder"
  },
  "dependencies": {
    "electron-store": "^11.0.2",
    "electron-updater": "^6.8.9"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "electron": "^29.0.0",
    "electron-builder": "^24.0.0",
    "typescript": "^5.0.0"
  },
  "build": {
    "appId": "com.agentops.orion",
    "productName": "Orion",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "src/overlay.html"
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/icon.ico",
      "publisherName": "AgentOps",
      "artifactName": "Orion-Setup-${version}.exe"
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/icon.icns"
    },
    "publish": {
      "provider": "github",
      "owner": "Vansh-codi",
      "repo": "Multi_Agent_Orchestration"
    }
  }
}
