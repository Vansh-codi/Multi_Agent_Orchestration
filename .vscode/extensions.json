{
  "recommendations": [
    // ── Python ───────────────────────────────────────────────
    "ms-python.python",              // Core Python support
    "ms-python.vscode-pylance",      // Fast type checking + IntelliSense
    "charliermarsh.ruff",            // Linting + formatting (replaces flake8/black)

    // ── Env files ────────────────────────────────────────────
    "mikestead.dotenv",              // .env syntax highlighting & secrets warning

    // ── Frontend ─────────────────────────────────────────────
    "dbaeumer.vscode-eslint",        // ESLint for Next.js
    "esbenp.prettier-vscode",        // Prettier formatter
    "bradlc.vscode-tailwindcss",     // Tailwind IntelliSense

    // ── Docker ───────────────────────────────────────────────
    "ms-azuretools.vscode-docker",   // Docker file support + container management

    // ── Database ─────────────────────────────────────────────
    "cweijan.vscode-postgresql-client2", // Browse PostgreSQL tables in sidebar

    // ── Git ───────────────────────────────────────────────────
    "eamodio.gitlens",               // Blame, history, PR integration

    // ── REST API testing ─────────────────────────────────────
    "humao.rest-client",             // Send HTTP requests from .http files

    // ── Productivity ─────────────────────────────────────────
    "usernamehw.errorlens",          // Inline error messages
    "streetsidesoftware.code-spell-checker"
  ]
}
