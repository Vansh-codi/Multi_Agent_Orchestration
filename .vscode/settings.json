{
  // ── Python interpreter ──────────────────────────────────────
  // Points to the virtual environment created by setup.sh
  "python.defaultInterpreterPath": "C:/Users/myvenv/Scripts/python.exe",

  // ── Linting & formatting ────────────────────────────────────
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.fixAll.ruff": "explicit",
    "source.organizeImports": "explicit"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff"
  },
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },
  "[json]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  },

  // ── Ruff config (fast Python linter + formatter) ─────────────
  "ruff.lint.args": ["--select=E,F,I,UP"],

  // ── Hide noisy folders from explorer ────────────────────────
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.venv": true,
    "**/node_modules": true,
    "**/.next": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.ruff_cache": true
  },

  // ── .env syntax highlighting ─────────────────────────────────
  "files.associations": {
    ".env*": "dotenv",
    ".env.example": "dotenv"
  },

  // ── Terminal: always open at workspace root ──────────────────
  "terminal.integrated.cwd": "${workspaceFolder}",

  // ── Env file for VS Code Python debugger ─────────────────────
  "python.envFile": "${workspaceFolder}/.env",

  // ── Test discovery ───────────────────────────────────────────
  "python.testing.pytestEnabled": true,
  "python.testing.pytestArgs": ["backend/tests"],

  // ── Editor comfort ───────────────────────────────────────────
  "editor.rulers": [88],
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "python-envs.defaultEnvManager": "ms-python.python:venv"
}
