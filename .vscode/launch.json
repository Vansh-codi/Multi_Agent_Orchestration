{
  "version": "0.2.0",
  "configurations": [
    {
      // ── FastAPI backend ─────────────────────────────────────
      "name": "FastAPI: dev server",
      "type": "debugpy",
      "request": "launch",
      "module": "uvicorn",
      "args": [
        "main:app",
        "--reload",
        "--host", "0.0.0.0",
        "--port", "8000"
      ],
      "cwd": "${workspaceFolder}/backend",
      "envFile": "${workspaceFolder}/.env",
      "justMyCode": false,
      "console": "integratedTerminal"
    },
    {
      // ── Next.js frontend ────────────────────────────────────
      "name": "Next.js: dev server",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/frontend",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal",
      "serverReadyAction": {
        "pattern": "started server on .+, url: (https?://.+)",
        "uriFormat": "%s",
        "action": "openExternally"
      }
    },
    {
      // ── Pytest ──────────────────────────────────────────────
      "name": "Pytest: run all tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["backend/tests", "-v"],
      "cwd": "${workspaceFolder}",
      "envFile": "${workspaceFolder}/.env",
      "console": "integratedTerminal"
    }
  ]
}
